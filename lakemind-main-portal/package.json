{
  "name": "@lakemind/main",
  "scripts": {
    "start": "cross-env REACT_APP_ENV=local webpack serve --mode development --port 9090",
    "startlocal": "cross-env REACT_APP_ENV=local webpack serve --port 9090 --mode development --no-client-overlay",
    "startdev": "cross-env REACT_APP_ENV=development webpack serve --port 9090 --mode development",
    "buildlocal": "cross-env REACT_APP_ENV=local node --max_old_space_size=8192 node_modules/.bin/webpack --mode=production",
    "buildlocaldeploy": "cross-env REACT_APP_ENV=local node --max_old_space_size=8192 node_modules/.bin/webpack --mode=production",
    "builddev": "cross-env REACT_APP_ENV=development node --max_old_space_size=8192 node_modules/.bin/webpack --mode=production",
    "buildproduction": "cross-env REACT_APP_ENV=production node --max_old_space_size=8192 node_modules/.bin/webpack --mode production",
    "build": "cross-env REACT_APP_ENV=production node --max_old_space_size=8192 node_modules/.bin/webpack --mode production",
    "start:standalone": "webpack serve --env standalone",
    "analyze": "webpack --mode=production --env analyze",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "test": "cross-env BABEL_ENV=test jest --passWithNoTests",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix"
  },
