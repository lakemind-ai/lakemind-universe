    "dotenv": "^16.5.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-ts-react-important-stuff": "^3.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-cli": "^30.3.0",
    "postcss-loader": "^8.2.1",
