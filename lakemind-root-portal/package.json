{
  "name": "@lakemind/root-config",
  "scripts": {
    "start": "cross-env ROOT_APP_ENV=local webpack serve --port 3003 --env isLocal",
    "startlocal": "cross-env ROOT_APP_ENV=local webpack serve --port 3003 --env isLocal --no-client-overlay",
    "startdev": "cross-env ROOT_APP_ENV=development webpack serve --port 3003 --env isLocal",
    "buildlocaldeploy": "cross-env ROOT_APP_ENV=localdeploy webpack --mode=production",
    "builddev": "cross-env ROOT_APP_ENV=development webpack --mode=production",
    "buildproduction": "cross-env ROOT_APP_ENV=production webpack --mode production",
    "build": "cross-env ROOT_APP_ENV=production webpack --mode production",
    "test": "cross-env BABEL_ENV=test jest --passWithNoTests",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix"
  },
  "devDependencies": {
    "@babel/core": "^7.23.3",
    "@babel/eslint-parser": "^7.23.3",
    "@babel/plugin-transform-runtime": "^7.23.3",
    "@babel/preset-env": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@babel/runtime": "^7.23.3",
    "concurrently": "^6.2.1",
    "copy-webpack-plugin": "^12.0.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-config-ts-important-stuff": "^1.1.0",
    "html-webpack-plugin": "^5.3.2",
    "jest": "^27.5.1",
    "jest-cli": "^27.5.1",
    "prettier": "3.6.2",
    "serve": "^13.0.0",
    "ts-config-single-spa": "^3.0.0",
    "typescript": "^4.3.5",
    "webpack": "^5.89.0",
    "webpack-cli": "^4.10.0",
    "webpack-config-single-spa-ts": "^4.0.0",
    "webpack-dev-server": "^4.0.0",
    "webpack-merge": "^5.8.0"
  },
  "dependencies": {
    "@types/jest": "^27.0.1",
    "@types/systemjs": "^6.1.1",
    "@types/webpack-env": "^1.16.2",
    "dotenv": "^16.4.7",
    "single-spa": "^5.9.3",
    "single-spa-layout": "^1.6.0"
  },
  "types": "dist/lakemind-root-config.d.ts"
}
