# LakeMind API Service — Environment Variables
# Copy this to .env and fill in your values

# ── Databricks connection ──────────────────────────────────────────────────
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=dapi...

# SQL Warehouse HTTP path (for ai_query and table scanning)
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your_warehouse_id

# OIDC (for Databricks Apps auth flow)
DATABRICKS_OIDC_CLIENT_ID=
DATABRICKS_OIDC_CLIENT_SECRET=

# ── Lakebase (Postgres) ───────────────────────────────────────────────────
# For local dev with a local Postgres instance:
USE_LOCAL_POSTGRES=true
PGHOST=localhost
PGPORT=5432
PGDATABASE=lakemind
PGUSER=postgres
PGPASSWORD=postgres

# For Databricks Apps (auto-injected — do not set manually):
# DATABRICKS_DATABASE_INSTANCE=lakemind-db
# DATABRICKS_DATABASE_NAME=lakemind

# ── App settings ──────────────────────────────────────────────────────────
SERVICE_NAME=LakeMindApp
LAKEMIND_AI_MODEL=databricks-meta-llama-3-1-70b-instruct
